# Docker / MySQL
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=utility_manager
MYSQL_USER=um_user
MYSQL_PASSWORD=change_me_user
MYSQL_PORT=3307

# Service ports
API_PORT=8001
FRONTEND_PORT=5173
ADMINER_PORT=8081

# Backend app settings
DATABASE_URL=mysql+pymysql://um_user:change_me_user@db:3306/utility_manager
APP_SECRET_KEY=change_me_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin
STORAGE_DIR=storage
TENANT_ACCESS_TOKEN_TTL_SECONDS=1800
TENANT_REFRESH_TOKEN_TTL_SECONDS=2592000

# Worker (optional): JSON array of provider sync targets.
# Example: [{"apartment_id":1,"provider":"manual_stub","source_ref":"manual"}]
PROVIDER_SYNC_TARGETS=[]
